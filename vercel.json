{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/solve",
      "dest": "api/solve.py"
    },
    {
      "src": "/api/validate",
      "dest": "api/validate.py"
    },
    {
      "src": "/api",
      "dest": "api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    }
  ]
}
